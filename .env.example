# ============================================================
# .env.example — 环境变量模板
# 使用步骤:
#   1. 复制为 .env: cp .env.example .env
#   2. 修改各项配置
#   3. 确保 .env 已加入 .gitignore (不要提交真实密码)
# ============================================================

DEBUG=True
SECRET_KEY=change-me-to-a-random-50-char-string

# ── MySQL ──────────────────────────────────────────────────
MYSQL_DATABASE=dpds
MYSQL_USER=dpds_user
MYSQL_PASSWORD=dpds_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# ── MongoDB ────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=dpds_algo

# ── Redis + Celery ─────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ── 文件存储 ────────────────────────────────────────────────
MEDIA_ROOT=media
MAX_UPLOAD_SIZE=2147483648

# ── 开发环境快捷配置 ─────────────────────────────────────────
# 如果本地无 MySQL，可以临时用 SQLite:
# USE_SQLITE=True

# ── Django 跨域 ─────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=True

# ── DeepSeek LLM（AI 报告生成）─────────────────────────────
# 设为 true 启用 AI 报告生成功能
ENABLE_LLM_REPORT=false
# 填入你的 DeepSeek API Key
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
