DEBUG=True
SECRET_KEY=dpds-dev-secret-key-change-in-production-2024

# 开发环境使用 SQLite
USE_SQLITE=True

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_DATABASE=dpds
MYSQL_USER=dpds_user
MYSQL_PASSWORD=dpds_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# ── MongoDB（可选，未启动时 MongoDB 存储会跳过，不影响启动）────
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=dpds_algo

# ── Redis + Celery（未启动时 Celery 会降级为 daemon thread）────
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ── 文件存储 ───────────────────────────────────────────────────
MEDIA_ROOT=media
MAX_UPLOAD_SIZE=2147483648

CORS_ALLOW_ALL_ORIGINS=True

# ── DeepSeek LLM ─────────────────────────────────────────────
ENABLE_LLM_REPORT=true
DEEPSEEK_API_KEY=sk-7d50d2e92815407a8f0f68df6a9294b8
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash